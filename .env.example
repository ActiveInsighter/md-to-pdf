# Cloudflare Worker secrets (set with: wrangler secret put NAME)
GITHUB_TOKEN=github_pat_replace_me
R2_ACCESS_KEY_ID=replace_me
R2_SECRET_ACCESS_KEY=replace_me
PDF_CALLBACK_SECRET=replace_with_long_random_secret
PDF_API_TOKEN=replace_with_long_random_access_token

# Cloudflare Worker non-secret variables (set in worker/wrangler.jsonc)
GITHUB_OWNER=ActiveInsighter
GITHUB_REPO=md-to-pdf
GITHUB_WORKFLOW_FILE=build-pdf-r2.yml
GITHUB_WORKFLOW_REF=main
R2_ACCOUNT_ID=replace_with_cloudflare_account_id
R2_BUCKET=md-to-pdf-jobs
FRONTEND_ORIGIN=https://replace-with-frontend.pages.dev
MAX_UPLOAD_BYTES=52428800
PRESIGNED_URL_TTL_SECONDS=600

# Frontend build variable
VITE_API_BASE_URL=https://replace-with-worker.workers.dev
