# Cloudflare Pages frontend variables (safe to expose)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key

# Supabase Edge Function custom secrets / configuration
GITHUB_TOKEN=github_pat_replace_me
GITHUB_OWNER=ActiveInsighter
GITHUB_REPO=md-to-pdf
GITHUB_WORKFLOW_FILE=build-pdf-api.yml
GITHUB_WORKFLOW_REF=main
PDF_STORAGE_BUCKET=pdf-jobs

# Hosted Edge Functions provide SUPABASE_URL and server/public keys automatically.

# GitHub Actions repository secrets
# SUPABASE_URL
# SUPABASE_SECRET_KEY (preferred)
# SUPABASE_SERVICE_ROLE_KEY (legacy fallback)
# SUPABASE_STORAGE_BUCKET
