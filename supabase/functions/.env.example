# Custom Edge Function secrets / configuration.
# The target repository, workflow file, and ref are fixed in start-pdf-job.
GITHUB_TOKEN=github_pat_replace_me
PDF_STORAGE_BUCKET=pdf-jobs

# Hosted Edge Functions automatically receive these built-in values:
# SUPABASE_URL
# SUPABASE_ANON_KEY
# SUPABASE_PUBLISHABLE_KEYS
# SUPABASE_SECRET_KEYS (hosted JSON dictionary, preferred)
# SUPABASE_SERVICE_ROLE_KEY (legacy fallback)
